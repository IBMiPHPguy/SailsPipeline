MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_DATABASE=sailspipeline
MYSQL_USER=cruiseapp
MYSQL_PASSWORD=cruisesecret

BACKEND_PORT=8000
FRONTEND_PORT=5173
NGINX_PORT=8080
NGINX_HTTPS_PORT=443

JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=480

# Legacy CRM admin placeholders — NOT applied on application startup.
# The API performs schema reconciliation only; no default tenant or demo users are created at boot.
# Use POST /api/public/register (dev) or Bridge onboarding to provision tenant workspaces.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@sailspipeline.com
SEED_ADMIN_PASSWORD=AdminPass1!

# Bridge launch only (one-time per environment — NOT application startup):
#   docker compose --profile launch run --rm bridge-launch
#   docker compose exec backend python scripts/bridge_launch.py
SEED_BRIDGE_ADMIN_USERNAME=bridge
SEED_BRIDGE_ADMIN_EMAIL=bridge@sailspipeline.com
SEED_BRIDGE_ADMIN_PASSWORD=BridgePass1!

ATTACHMENTS_DIR=/app/uploads

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Application environment tier: development | staging | production
APP_ENV=development

# Security (development defaults)
ALLOW_PUBLIC_REGISTRATION=true
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://127.0.0.1:8080
EXPOSE_OPENAPI=true
AUTH_RATE_LIMIT=10/minute

# Agency analytics rollups
ROLLUP_SCHEDULER_ENABLED=true
ROLLUP_REFRESH_POLL_SECONDS=30
ROLLUP_DAILY_REFRESH_HOUR_UTC=3

# Trial workspace locking (new agencies start Trialing; scheduler locks after TRIAL_PERIOD_DAYS)
TRIAL_PERIOD_DAYS=7
TRIAL_SCHEDULER_ENABLED=true
TRIAL_SCHEDULER_POLL_SECONDS=300

# Invitation expiry
PLATFORM_INVITE_EXPIRE_DAYS=7
AGENCY_INVITE_EXPIRE_DAYS=3

# Transactional email — routing is automatic from APP_ENV:
#   development -> Mailpit SMTP (SMTP_HOST:SMTP_PORT; default mailpit:1025; UI at http://localhost:8025)
#   staging     -> Mailgun REST API (MAILGUN_API_KEY_STAGING required)
#   production  -> Mailgun REST API (MAILGUN_API_KEY required)
SMTP_HOST=mailpit
SMTP_PORT=1025
MAILGUN_DOMAIN=mail.sailspipeline.com
MAILGUN_API_KEY=
MAILGUN_API_KEY_STAGING=

# Legacy aliases (optional; MAILGUN_* takes precedence)
EMAIL_FROM_ADDRESS=notifications@sailspipeline.com
EMAIL_API_KEY=
EMAIL_API_KEY_STAGING=

# Base URL for password-reset links and other user-facing email CTAs (no trailing slash).
# Use the Nginx entry point in local Docker so links work from Mailpit previews.
PUBLIC_APP_BASE_URL=http://localhost:8080
# Canonical HTTPS origin for brand logos and signature images embedded in email HTML.
# In production this should match the host that serves /static/uploads (typically the app domain).
BRAND_ASSET_PUBLIC_BASE_URL=

# Unauthenticated passenger portal base URLs (no trailing slash)
CC_AUTH_PORTAL_BASE_URL=http://localhost:8080/cc-auth
TERMS_PORTAL_BASE_URL=http://localhost:8080/accept-terms
INSURANCE_PORTAL_BASE_URL=http://localhost:8080/insurance-auth

# Transient card vault (Fernet). Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CC_AUTH_ENCRYPTION_KEY=
CC_AUTH_VAULT_ACCESS_KEY=dev-vault-access-change-me

# Agency white-label logos and signature images (local dev writes under backend/static/uploads)
BRAND_UPLOADS_DIR=static/uploads

# Cloud brand asset storage (required when APP_ENV=staging or production)
S3_BRAND_BUCKET=
S3_BRAND_REGION=us-east-1
S3_BRAND_PUBLIC_BASE_URL=

# Production example (use with docker-compose.prod.yml):
# APP_ENV=production
# MAILGUN_API_KEY=<live-mailgun-key>
# JWT_SECRET=<random-string-at-least-32-characters>
# ALLOW_PUBLIC_REGISTRATION=false
# EXPOSE_OPENAPI=false
# CORS_ORIGINS=https://your-domain.example
# PUBLIC_APP_BASE_URL=https://your-domain.example
# BRAND_ASSET_PUBLIC_BASE_URL=https://app.sailspipeline.com
# S3_BRAND_BUCKET=your-brand-assets-bucket
# CC_AUTH_ENCRYPTION_KEY=<fernet-key>
# CC_AUTH_VAULT_ACCESS_KEY=<strong-random-access-key>
